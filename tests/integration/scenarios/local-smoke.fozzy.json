{
  "version": 1,
  "name": "local-smoke",
  "steps": [
    {
      "type": "proc_when",
      "cmd": "cargo",
      "args": ["test", "--workspace"],
      "exit_code": 0,
      "stdout": "",
      "stderr": "",
      "times": 1
    },
    {
      "type": "proc_when",
      "cmd": "cargo",
      "args": ["test", "-p", "fabric", "reconcile_sessions"],
      "exit_code": 0,
      "stdout": "",
      "stderr": "",
      "times": 1
    },
    {
      "type": "proc_when",
      "cmd": "cargo",
      "args": ["run", "-p", "quip", "--", "status"],
      "exit_code": 0,
      "stdout": "",
      "stderr": "",
      "times": 1
    },
    {
      "type": "proc_when",
      "cmd": "cargo",
      "args": ["run", "-p", "quipd", "--", "--one-shot", "--force-network-reprobe", "--network-change-trigger-path", "/tmp/quip-network-change.trigger"],
      "exit_code": 0,
      "stdout": "",
      "stderr": "",
      "times": 1
    },
    {
      "type": "proc_when",
      "cmd": "cargo",
      "args": ["run", "-p", "quip", "--", "path", "watch", "--sample-limit", "1"],
      "exit_code": 0,
      "stdout": "",
      "stderr": "",
      "times": 1
    },
    {
      "type": "proc_spawn",
      "cmd": "cargo",
      "args": ["run", "-p", "quip", "--", "status"],
      "expect_exit": 0
    }
  ]
}
