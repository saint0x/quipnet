{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quip.example/schemas/state/state.schema.json",
  "title": "Quip Durable Network State",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "network",
    "local_peer_id",
    "roles",
    "membership",
    "capability_grants",
    "revocations",
    "denied_peers",
    "bootstrap",
    "relay_map",
    "peers",
    "netcheck",
    "queue_policies",
    "path_candidates"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "network": {
      "type": "string",
      "minLength": 1
    },
    "local_peer_id": {
      "type": "string",
      "minLength": 1
    },
    "roles": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["Bootstrap", "Relay", "Observer", "Edge"]
      }
    },
    "membership": {
      "$ref": "#/$defs/membership_certificate"
    },
    "capability_grants": {
      "type": "array",
      "items": { "$ref": "#/$defs/capability_grant" }
    },
    "revocations": {
      "type": "array",
      "items": { "$ref": "#/$defs/revocation_record" }
    },
    "denied_peers": {
      "type": "array",
      "items": { "$ref": "#/$defs/denied_peer" }
    },
    "bootstrap": {
      "type": "array",
      "items": { "$ref": "#/$defs/bootstrap_endpoint" }
    },
    "relay_map": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["version", "generated_at", "relays"],
      "properties": {
        "version": { "type": "integer", "minimum": 1 },
        "generated_at": { "type": "integer", "minimum": 0 },
        "relays": {
          "type": "array",
          "items": { "$ref": "#/$defs/relay_announcement" }
        }
      }
    },
    "peers": {
      "type": "array",
      "items": { "$ref": "#/$defs/peer_inspection" }
    },
    "netcheck": {
      "$ref": "#/$defs/netcheck_report"
    },
    "queue_policies": {
      "type": "array",
      "items": { "$ref": "#/$defs/queue_policy" }
    },
    "path_candidates": {
      "type": "array",
      "items": { "$ref": "#/$defs/path_candidate" }
    }
  },
  "$defs": {
    "bootstrap_endpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["peer", "addresses", "protocols", "metadata"],
      "properties": {
        "peer": { "type": ["string", "null"] },
        "addresses": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "protocols": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "metadata": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "membership_certificate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "network_id",
        "subject_peer_id",
        "issuer_peer_id",
        "issued_at",
        "expires_at",
        "roles",
        "signature"
      ],
      "properties": {
        "network_id": { "type": "string", "minLength": 1 },
        "subject_peer_id": { "type": "string", "minLength": 1 },
        "issuer_peer_id": { "type": "string", "minLength": 1 },
        "issued_at": { "type": "integer", "minimum": 0 },
        "expires_at": { "type": "integer", "minimum": 0 },
        "roles": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "signature": { "$ref": "#/$defs/signature_bytes" }
      }
    },
    "capability_grant": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "network_id",
        "subject_peer_id",
        "issuer_peer_id",
        "capabilities",
        "protocol_scopes",
        "resource_limits",
        "constraints",
        "not_before",
        "expires_at",
        "sequence",
        "signature"
      ],
      "properties": {
        "network_id": { "type": "string", "minLength": 1 },
        "subject_peer_id": { "type": "string", "minLength": 1 },
        "issuer_peer_id": { "type": "string", "minLength": 1 },
        "capabilities": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "protocol_scopes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "resource_limits": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "bandwidth_bps",
            "concurrent_streams",
            "max_object_bytes"
          ],
          "properties": {
            "bandwidth_bps": { "type": ["integer", "null"], "minimum": 0 },
            "concurrent_streams": { "type": ["integer", "null"], "minimum": 0 },
            "max_object_bytes": { "type": ["integer", "null"], "minimum": 0 }
          }
        },
        "constraints": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "not_before": { "type": "integer", "minimum": 0 },
        "expires_at": { "type": "integer", "minimum": 0 },
        "sequence": { "type": "integer", "minimum": 0 },
        "signature": { "$ref": "#/$defs/signature_bytes" }
      }
    },
    "revocation_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "network_id",
        "issuer_peer_id",
        "target",
        "reason",
        "issued_at",
        "effective_at",
        "sequence",
        "note",
        "signature"
      ],
      "properties": {
        "network_id": { "type": "string", "minLength": 1 },
        "issuer_peer_id": { "type": "string", "minLength": 1 },
        "target": { "type": "object", "minProperties": 1 },
        "reason": {
          "type": "string",
          "enum": [
            "Administrative",
            "KeyCompromise",
            "Superseded",
            "Unspecified"
          ]
        },
        "issued_at": { "type": "integer", "minimum": 0 },
        "effective_at": { "type": "integer", "minimum": 0 },
        "sequence": { "type": "integer", "minimum": 0 },
        "note": { "type": ["string", "null"] },
        "signature": { "$ref": "#/$defs/signature_bytes" }
      }
    },
    "denied_peer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["peer", "reason"],
      "properties": {
        "peer": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 }
      }
    },
    "relay_announcement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "peer_id",
        "region",
        "advertised_endpoints",
        "control_endpoint",
        "max_bandwidth_bps",
        "supports_quic_datagrams",
        "supports_path_migration",
        "traffic_classes"
      ],
      "properties": {
        "peer_id": { "type": "string", "minLength": 1 },
        "region": { "type": "string", "minLength": 1 },
        "advertised_endpoints": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "control_endpoint": { "type": "string" },
        "max_bandwidth_bps": { "type": "integer", "minimum": 0 },
        "supports_quic_datagrams": { "type": "boolean" },
        "supports_path_migration": { "type": "boolean" },
        "traffic_classes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "peer_inspection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["snapshot", "status", "record_count"],
      "properties": {
        "snapshot": {
          "type": "object",
          "additionalProperties": false,
          "required": ["peer", "protocols", "addresses"],
          "properties": {
            "peer": { "type": "string", "minLength": 1 },
            "protocols": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            },
            "addresses": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            }
          }
        },
        "status": {
          "type": "object",
          "additionalProperties": false,
          "required": ["source", "reachability", "last_seen_unix_secs"],
          "properties": {
            "source": {
              "type": "string",
              "enum": ["Bootstrap", "RelayMap", "Discovery", "Manual", "Observed"]
            },
            "reachability": {
              "type": "string",
              "enum": ["Unknown", "Direct", "Relayed", "Unreachable"]
            },
            "last_seen_unix_secs": {
              "type": ["integer", "null"],
              "minimum": 0
            }
          }
        },
        "record_count": { "type": "integer", "minimum": 0 }
      }
    },
    "netcheck_report": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "nat_type",
        "udp_reachable",
        "ipv6_reachable",
        "hairpin_supported",
        "public_udp_addr",
        "port_mapped",
        "probe_observations"
      ],
      "properties": {
        "nat_type": {
          "type": "string",
          "enum": [
            "Unknown",
            "OpenInternet",
            "FullCone",
            "RestrictedCone",
            "PortRestrictedCone",
            "Symmetric",
            "UdpBlocked"
          ]
        },
        "udp_reachable": { "type": "boolean" },
        "ipv6_reachable": { "type": "boolean" },
        "hairpin_supported": { "type": "boolean" },
        "public_udp_addr": { "type": ["string", "null"] },
        "port_mapped": { "type": "boolean" },
        "probe_observations": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["vantage", "status", "latency_ms", "detail"],
            "properties": {
              "vantage": { "type": "string", "minLength": 1 },
              "status": {
                "type": "string",
                "enum": ["Pending", "Passed", "Failed"]
              },
              "latency_ms": { "type": ["integer", "null"], "minimum": 0 },
              "detail": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "queue_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["class", "max_inflight_messages", "drop_stale"],
      "properties": {
        "class": {
          "type": "string",
          "enum": ["Control", "Interactive", "Bulk", "Background"]
        },
        "max_inflight_messages": { "type": "integer", "minimum": 0 },
        "drop_stale": { "type": "boolean" }
      }
    },
    "path_candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "peer",
        "path_kind",
        "relay_peer",
        "source",
        "traffic_classes",
        "rtt_ms",
        "jitter_ms",
        "loss_pct",
        "throughput_mbps",
        "relay_penalty"
      ],
      "properties": {
        "peer": { "type": "string", "minLength": 1 },
        "path_kind": {
          "type": "string",
          "enum": ["DirectUdp", "DirectIpv6", "Relay", "Loopback", "Lan"]
        },
        "relay_peer": { "type": ["string", "null"] },
        "source": {
          "type": "string",
          "enum": ["Observed", "Bootstrap", "AuthorityRelay"]
        },
        "traffic_classes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["Control", "Interactive", "Bulk", "Background"]
          }
        },
        "rtt_ms": { "type": "integer", "minimum": 0 },
        "jitter_ms": { "type": "integer", "minimum": 0 },
        "loss_pct": { "type": "number", "minimum": 0 },
        "throughput_mbps": { "type": "integer", "minimum": 0 },
        "relay_penalty": { "type": "integer", "minimum": 0 }
      }
    },
    "signature_bytes": {
      "type": "array",
      "items": {
        "type": "integer",
        "minimum": 0,
        "maximum": 255
      }
    }
  }
}
