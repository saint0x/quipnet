{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quip.example/schemas/daemon/runtime.paths.list.response.schema.json",
  "allOf": [
    { "$ref": "./common.schema.json#/$defs/success_response" },
    {
      "properties": {
        "result": {
          "type": "object",
          "additionalProperties": false,
          "required": ["truth_kind", "paths"],
          "properties": {
            "truth_kind": { "const": "runtime" },
            "paths": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "peer_id",
                  "class",
                  "state",
                  "path_class",
                  "source",
                  "endpoint_summary",
                  "summary",
                  "alternatives"
                ],
                "properties": {
                  "session_id": {
                    "type": ["string", "null"],
                    "minLength": 1
                  },
                  "peer_id": { "type": "string", "minLength": 1 },
                  "protocol": {
                    "type": ["string", "null"],
                    "minLength": 1
                  },
                  "class": {
                    "type": "string",
                    "enum": ["control", "interactive", "bulk", "background"]
                  },
                  "state": {
                    "type": "string",
                    "enum": ["active", "degraded", "migrating", "failed", "suppressed"]
                  },
                  "path_class": {
                    "type": "string",
                    "enum": ["direct", "relay", "unknown"]
                  },
                  "source": {
                    "type": "string",
                    "enum": ["observed", "bootstrap", "authority_relay", "runtime"]
                  },
                  "relay_peer_id": {
                    "type": ["string", "null"],
                    "minLength": 1
                  },
                  "endpoint_summary": { "type": "string", "minLength": 1 },
                  "score": {
                    "type": ["integer", "null"],
                    "minimum": 0
                  },
                  "state_reason": {
                    "type": ["string", "null"],
                    "minLength": 1
                  },
                  "summary": { "type": "string", "minLength": 1 },
                  "alternatives": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["path_class", "source", "score", "summary"],
                      "properties": {
                        "path_class": {
                          "type": "string",
                          "enum": ["direct", "relay", "unknown"]
                        },
                        "source": {
                          "type": "string",
                          "enum": ["observed", "bootstrap", "authority_relay", "runtime"]
                        },
                        "relay_peer_id": {
                          "type": ["string", "null"],
                          "minLength": 1
                        },
                        "score": { "type": "integer", "minimum": 0 },
                        "summary": { "type": "string", "minLength": 1 }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  ]
}
