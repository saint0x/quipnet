{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quip.example/schemas/daemon/runtime.status.response.schema.json",
  "allOf": [
    { "$ref": "./common.schema.json#/$defs/success_response" },
    {
      "properties": {
        "result": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "truth_kind",
            "daemon_health",
            "identity",
            "durable_state",
            "authority",
            "runtime_summary"
          ],
          "properties": {
            "truth_kind": { "const": "runtime" },
            "daemon_health": {
              "type": "string",
              "enum": ["ready", "degraded", "failed", "starting", "suppressed"]
            },
            "identity": {
              "type": "object",
              "additionalProperties": false,
              "required": ["status", "path", "node_id"],
              "properties": {
                "status": {
                  "type": "string",
                  "enum": ["loaded", "missing", "invalid"]
                },
                "path": { "type": "string", "minLength": 1 },
                "node_id": { "type": "string", "minLength": 1 }
              }
            },
            "durable_state": {
              "type": "object",
              "additionalProperties": false,
              "required": ["status", "path", "schema_version"],
              "properties": {
                "status": {
                  "type": "string",
                  "enum": ["loaded", "missing", "invalid"]
                },
                "path": { "type": "string", "minLength": 1 },
                "schema_version": { "type": "integer", "minimum": 1 }
              }
            },
            "authority": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "sync_status",
                "last_accepted_revision",
                "health",
                "local_policy_denied",
                "authority_subject_mismatch",
                "reevaluated_sessions",
                "closed_sessions",
                "degraded_sessions",
                "migrated_sessions",
                "unchanged_sessions",
                "reevaluated_listeners",
                "suppressed_listeners",
                "restored_listeners",
                "reconnect_suppressions_added",
                "reconnect_suppressions_cleared",
                "local_policy_reason"
              ],
              "properties": {
                "sync_status": {
                  "type": "string",
                  "enum": ["in_sync", "syncing", "stale", "failed", "policy_enforced", "subject_mismatch"]
                },
                "last_accepted_revision": {
                  "type": "string",
                  "minLength": 1
                },
                "health": {
                  "type": "string",
                  "enum": ["ready", "degraded", "failed", "suppressed"]
                },
                "local_policy_denied": { "type": "boolean" },
                "authority_subject_mismatch": { "type": "boolean" },
                "reevaluated_sessions": { "type": "integer", "minimum": 0 },
                "closed_sessions": { "type": "integer", "minimum": 0 },
                "degraded_sessions": { "type": "integer", "minimum": 0 },
                "migrated_sessions": { "type": "integer", "minimum": 0 },
                "unchanged_sessions": { "type": "integer", "minimum": 0 },
                "reevaluated_listeners": { "type": "integer", "minimum": 0 },
                "suppressed_listeners": { "type": "integer", "minimum": 0 },
                "restored_listeners": { "type": "integer", "minimum": 0 },
                "reconnect_suppressions_added": { "type": "integer", "minimum": 0 },
                "reconnect_suppressions_cleared": { "type": "integer", "minimum": 0 },
                "local_policy_reason": {
                  "type": ["string", "null"]
                }
              }
            },
            "runtime_summary": {
              "type": "object",
              "additionalProperties": false,
              "required": ["session_count", "active_path_count", "reconnect_state"],
              "properties": {
                "session_count": { "type": "integer", "minimum": 0 },
                "active_path_count": { "type": "integer", "minimum": 0 },
                "reconnect_state": {
                  "type": "string",
                  "enum": ["idle", "active", "suppressed", "failed"]
                }
              }
            }
          }
        }
      }
    }
  ]
}
