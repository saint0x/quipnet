{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quip.example/schemas/daemon/session.connect.request.schema.json",
  "allOf": [
    { "$ref": "./common.schema.json#/$defs/request_envelope" },
    {
      "properties": {
        "operation": { "const": "session.connect" },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": ["peer_id"],
          "properties": {
            "peer_id": {
              "type": "string",
              "minLength": 1
            },
            "path_preference": {
              "type": "string",
              "enum": [
                "direct_preferred",
                "relay_preferred",
                "direct_only",
                "relay_only",
                "any"
              ]
            }
          }
        }
      }
    }
  ]
}
