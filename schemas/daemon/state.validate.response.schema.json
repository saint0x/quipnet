{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quip.example/schemas/daemon/state.validate.response.schema.json",
  "allOf": [
    { "$ref": "./common.schema.json#/$defs/success_response" },
    {
      "properties": {
        "result": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "truth_kind",
            "state_path",
            "present",
            "schema_version",
            "valid",
            "violations"
          ],
          "properties": {
            "truth_kind": { "const": "durable" },
            "state_path": { "type": "string", "minLength": 1 },
            "present": { "type": "boolean" },
            "schema_version": {
              "type": ["integer", "null"],
              "minimum": 1
            },
            "valid": { "type": "boolean" },
            "violations": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["path", "message"],
                "properties": {
                  "path": { "type": "string", "minLength": 1 },
                  "message": { "type": "string", "minLength": 1 }
                }
              }
            }
          }
        }
      }
    }
  ]
}
