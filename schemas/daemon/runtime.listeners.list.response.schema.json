{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quip.example/schemas/daemon/runtime.listeners.list.response.schema.json",
  "allOf": [
    { "$ref": "./common.schema.json#/$defs/success_response" },
    {
      "properties": {
        "result": {
          "type": "object",
          "additionalProperties": false,
          "required": ["truth_kind", "listeners"],
          "properties": {
            "truth_kind": { "const": "runtime" },
            "listeners": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "listener_id",
                  "transport",
                  "bind_summary",
                  "protocol",
                  "advertise",
                  "state",
                  "age_seconds"
                ],
                "properties": {
                  "listener_id": { "type": "string", "minLength": 1 },
                  "transport": { "type": "string", "minLength": 1 },
                  "bind_summary": { "type": "string", "minLength": 1 },
                  "protocol": { "type": "string", "minLength": 1 },
                  "advertise": { "type": "boolean" },
                  "state": {
                    "type": "string",
                    "enum": ["active", "failed"]
                  },
                  "age_seconds": { "type": "integer", "minimum": 0 }
                }
              }
            }
          }
        }
      }
    }
  ]
}
