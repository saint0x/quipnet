{
  "version": 1,
  "seed_policy": {
    "mode": "deterministic_required",
    "default_seed": 424242
  },
  "doctor_defaults": {
    "runs": 5,
    "strict": true
  },
  "scenarios": [
    {
      "id": "clean-bootstrap",
      "scenario_path": "tests/integration/scenarios/local-smoke.fozzy.json",
      "priority": 1,
      "description": "Node starts from valid durable identity and durable state and reaches healthy runtime status.",
      "checks": [
        "daemon_health_ready",
        "identity_loaded",
        "durable_state_loaded",
        "authority_bootstrap_visible"
      ],
      "focus": ["startup", "status", "authority"]
    },
    {
      "id": "restart-preserved-identity",
      "scenario_path": "tests/integration/scenarios/restart-smoke.fozzy.json",
      "priority": 1,
      "description": "Restart preserves identity and durable state without falsely restoring runtime sessions.",
      "checks": [
        "identity_stable_after_restart",
        "durable_state_reused_honestly",
        "stale_runtime_references_rejected",
        "runtime_instance_rotates_per_daemon_run"
      ],
      "focus": ["restart", "runtime_ownership", "durable_vs_runtime"]
    },
    {
      "id": "network-state-reset-preserved-identity",
      "scenario_path": "tests/integration/scenarios/state-recovery-smoke.fozzy.json",
      "priority": 1,
      "description": "Network state reset preserves identity and requires honest re-bootstrap.",
      "checks": [
        "identity_preserved",
        "network_state_reset",
        "bootstrap_required_after_reset"
      ],
      "focus": ["state_reset", "identity_preservation", "bootstrap"]
    },
    {
      "id": "authority-sync-membership-update",
      "scenario_path": "tests/integration/scenarios/authority-reevaluation-smoke.fozzy.json",
      "priority": 1,
      "description": "Authority sync updates accepted facts and exposes resulting runtime impact.",
      "checks": [
        "authority_sync_visible",
        "accepted_facts_updated",
        "runtime_reevaluation_triggered",
        "authority_policy_enforcement_visible"
      ],
      "focus": ["authority", "membership", "reevaluation"]
    },
    {
      "id": "revocation-enforcement",
      "scenario_path": "tests/integration/scenarios/authority-reevaluation-smoke.fozzy.json",
      "priority": 1,
      "description": "Revocation changes propagate into runtime behavior and reconnect policy.",
      "checks": [
        "revocation_detected",
        "policy_driven_session_action_visible",
        "reconnect_suppression_visible",
        "revocation_reason_visible"
      ],
      "focus": ["revocation", "policy", "runtime_enforcement"]
    },
    {
      "id": "capability-change",
      "scenario_path": "tests/integration/scenarios/authority-reevaluation-smoke.fozzy.json",
      "priority": 1,
      "description": "Capability changes reevaluate runtime behavior correctly.",
      "checks": [
        "capability_change_visible",
        "runtime_behavior_reevaluated",
        "durable_and_runtime_policy_alignment"
      ],
      "focus": ["capabilities", "policy_drift", "runtime_reevaluation"]
    },
    {
      "id": "direct-path-success",
      "scenario_path": "tests/integration/scenarios/local-smoke.fozzy.json",
      "priority": 2,
      "description": "Direct path establishment succeeds and is reported honestly.",
      "checks": [
        "session_connect_succeeds",
        "direct_path_selected",
        "runtime_path_visible"
      ],
      "focus": ["direct_path", "session_connect", "runtime_paths"]
    },
    {
      "id": "relay-fallback",
      "scenario_path": "tests/integration/scenarios/relay-migration-smoke.fozzy.json",
      "priority": 2,
      "description": "Relay fallback is used when direct connectivity is unavailable and is visible to operators.",
      "checks": [
        "relay_path_selected",
        "fallback_reason_visible",
        "session_continuity_preserved"
      ],
      "focus": ["relay", "fallback", "path_choice"]
    },
    {
      "id": "path-migration",
      "scenario_path": "tests/integration/scenarios/relay-migration-smoke.fozzy.json",
      "priority": 2,
      "description": "Session path migration is daemon-owned and observable.",
      "checks": [
        "migration_started_visible",
        "migration_completed_visible",
        "active_path_updated_honestly"
      ],
      "focus": ["path_migration", "runtime_events", "path_state"]
    },
    {
      "id": "runtime-event-contract",
      "scenario_path": "tests/integration/scenarios/reconnect-smoke.fozzy.json",
      "priority": 1,
      "description": "Runtime event fixtures, daemon responses, and emitted reconnect transitions stay aligned.",
      "checks": [
        "runtime_event_schema_matches_emission",
        "reconnect_unsuppressed_visible",
        "daemon_runtime_events_preserve_truth_kind"
      ],
      "focus": ["runtime_events", "reconnect", "operator_surface"]
    },
    {
      "id": "runtime-diagnosis",
      "scenario_path": "tests/integration/scenarios/runtime-diagnosis-smoke.fozzy.json",
      "priority": 1,
      "description": "Runtime diagnosis classifies durable, authority, and runtime failures while preserving terminal session visibility.",
      "checks": [
        "mixed_issue_classification_visible",
        "terminal_session_history_visible",
        "runtime_contract_fixture_aligned"
      ],
      "focus": ["runtime_diagnose", "operator_surface", "terminal_history"]
    },
    {
      "id": "reconnect-after-drop",
      "scenario_path": "tests/integration/scenarios/reconnect-smoke.fozzy.json",
      "priority": 1,
      "description": "Reconnect after drop follows daemon-owned policy with deterministic retry behavior.",
      "checks": [
        "drop_detected",
        "retry_policy_visible",
        "reconnect_outcome_visible",
        "bounded_backoff_visible",
        "runtime_health_reconnect_state_visible"
      ],
      "focus": ["reconnect", "drop_recovery", "runtime_policy"]
    },
    {
      "id": "durable-state-validation-failure",
      "scenario_path": "tests/integration/scenarios/state-recovery-smoke.fozzy.json",
      "priority": 1,
      "description": "Invalid durable state fails validation clearly and safely.",
      "checks": [
        "invalid_state_rejected",
        "schema_violation_reported",
        "startup_fails_safely"
      ],
      "focus": ["state_schema", "validation_failure", "safe_startup"]
    },
    {
      "id": "backup-and-restore",
      "scenario_path": "tests/integration/scenarios/backup-restore-smoke.fozzy.json",
      "priority": 1,
      "description": "Backup and restore preserve the same logical node contract without confusing restore and rotation semantics.",
      "checks": [
        "identity_restored",
        "network_state_restored",
        "restore_writes_canonical_paths"
      ],
      "focus": ["backup", "restore", "identity_vs_network_state"]
    },
    {
      "id": "state-export-surface",
      "scenario_path": "tests/integration/scenarios/backup-restore-smoke.fozzy.json",
      "priority": 1,
      "description": "Daemon-backed state export produces encrypted bundles and the offline restore path preserves the same logical node contract.",
      "checks": [
        "bundle_export_succeeds",
        "bundle_restore_roundtrips",
        "offline_restore_guard_visible"
      ],
      "focus": ["backup", "restore", "operator_surface"]
    }
  ]
}
